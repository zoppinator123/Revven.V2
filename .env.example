# Revven.V2 — environment variables
# Copy to .env for local dev, or set these in Vercel Project Settings → Environment Variables.
# DO NOT commit a populated .env to git.

# --- HavenOS / Supabase (Haven Vacation Rentals shared backend) ---
# Use the Haven Supabase project credentials. SUPABASE_URL is the project URL,
# SUPABASE_ANON_KEY is safe for client-side use, SUPABASE_SERVICE_ROLE_KEY is
# server-only and must never be exposed to the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI / analysis ---
GROQ_API_KEY=

# --- PriceLabs (revenue management) ---
PRICELABS_API_KEY=
PRICELABS_EMAIL=
PRICELABS_PASSWORD=
# Optional, comma-separated endpoint templates run after a pricing apply, e.g.
# "POST /listings/{listing_id}/refresh, POST /listings/{listing_id}/sync"
PRICELABS_POST_APPLY_ENDPOINTS=

# --- Booking.com Connectivity (Promotions API) ---
BOOKING_CLIENT_ID=
BOOKING_CLIENT_SECRET=

# --- Hostaway (PMS) ---
HOSTAWAY_API_TOKEN=

# --- Wheelhouse (legacy / optional) ---
WHEELHOUSE_API_KEY=
